.mcp-settings .mcp-chat-item-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.mcp-settings .mcp-chat-item-del {
  background: transparent; border: 0; cursor: pointer; font-size: 14px; color: #888; padding: 0 4px;
}
.mcp-settings .mcp-chat-item-del:hover { color: #b00; }

.mcp-settings .mcp-chat-main {
